# ——— Form delivery (FormSubmit) ———
# The destination for enquiry submissions. Two accepted formats:
#
# 1. The raw inbox. The FIRST submission triggers a FormSubmit activation
#    email to this address — someone must click the link inside it once:
#      FORMSUBMIT_TARGET=info@beyondhome.com.ng
#
# 2. Preferred once activated: the random alias FormSubmit issues (find it
#    at https://formsubmit.co after activation). Keeps the real inbox out
#    of every request:
#      FORMSUBMIT_TARGET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6
FORMSUBMIT_TARGET=info@beyondhome.com.ng

# ——— Canonical site URL ———
# Used for metadataBase, canonical links, sitemap and JSON-LD.
# TODO-CLIENT: confirm the final production domain.
NEXT_PUBLIC_SITE_URL=https://beyondhome.com.ng
